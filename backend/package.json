{
  "name": "quantis-backend",
  "version": "1.0.0",
  "description": "Quantis API: PostgreSQL (production/Portal) + tùy chọn JSON file server (dev/proxy)",
  "type": "module",
  "main": "dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./embed": "./dist/embed.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "node json-server.cjs",
    "dev:postgres": "tsc && node dist/server.js",
    "watch": "tsc --watch",
    "start:json": "node json-server.cjs"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "cookie-session": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-session": "^1.18.0",
    "form-data": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "openid-client": "^5.6.1",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.6",
    "typescript": "^5.3.3"
  }
}
