# Sao chép file này thành .env và chỉnh giá trị nếu cần.
# Backend Node sẽ đọc các biến khi khởi động (npm run dev hoặc node server.js).

# Port chạy backend Node (mặc định 4001)
# PORT=4001

# URL backend phân tích Python/R (FastAPI, mặc định chạy port 4000).
# Nếu set, backend Node sẽ proxy /api/quantis/analyze/* sang đây.
# Để tắt tính năng "Backend phân tích": không set hoặc để trống.
ANALYZE_PYTHON_URL=http://localhost:4000

# (Tùy chọn) Archive NEU
# ARCHIVE_NEU_URL=https://archive.neu.edu.vn
# ARCHIVE_NEU_TOKEN=

# (Tùy chọn) Ollama
# OLLAMA_URL=https://research.neu.edu.vn/ollama
