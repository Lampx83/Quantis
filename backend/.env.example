# =============================================================================
# Quantis backend — một thư mục, hai chế độ:
#   • PostgreSQL: npm run build && npm start  (mặc định PORT 4003)
#   • JSON + proxy: npm run start:json        (mặc định PORT 4001, file json-server.cjs)
# Sao chép thành .env và bỏ comment phần bạn dùng.
# =============================================================================

# --- A) PostgreSQL (npm start sau khi build) — production / SurveyLab / AI Portal ---

RUN_MODE=standalone
PORT=4003
DB_SCHEMA=quantis

# DATABASE_URL=postgresql://user:pass@localhost:5432/quantis
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=quantis

# Auth (standalone) — giống SurveyLab
# Mặc định không set AUTH_*: standalone vẫn BẬT đăng nhập + BẮT BUỘC phiên.
# AUTH_ENABLED=0  → tắt auth (dev)
# AUTH_REQUIRED=0 → đăng nhập tùy chọn
SESSION_SECRET=change-me-in-production
# ADMIN_EMAILS=admin@example.com

# SSO OIDC (tuỳ chọn)
# SSO_ISSUER_URL=https://...
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_CALLBACK_URL=http://localhost:4003/api/quantis/auth/sso/callback

# AI Portal (embed): PORTAL_DATABASE_URL + RUN_MODE=embedded — import createEmbedRouter từ backend/dist/embed.js

# --- B) JSON server (npm run start:json) — dev nhanh, proxy Archive/Ollama/Python ---

# PORT=4001
# ANALYZE_PYTHON_URL=http://localhost:4000
# ARCHIVE_NEU_URL=https://archive.neu.edu.vn
# ARCHIVE_NEU_TOKEN=
# OLLAMA_URL=http://127.0.0.1:11434
# QUANTIS_AUTH_ENABLED=1
# QUANTIS_AUTH_REQUIRED=1
# SESSION_SECRET=thay-bang-chuoi-ngau-nhien-dai
# QUANTIS_ADMIN_EMAILS=admin@example.com
# QUANTIS_SSO_REDIRECT_URL=
# QUANTIS_SSO_LABEL=Đăng nhập SSO
# COOKIE_SECURE=1
